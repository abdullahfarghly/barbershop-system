{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{"name": "next"}],
    "ignoreDeprecations": "6.0", // 🔓 إضافة هذا السطر لإسكات التحذير ومنع توقف الـ Build
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"] // 🎯 الحفاظ التام على اللوجيك ومسارات الاستدعاء الحالية في المشروع
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}